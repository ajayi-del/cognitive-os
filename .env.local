# ==========================================
# Cognitive OS - Complete Environment Configuration
# ==========================================

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL="postgresql://localhost:5432/cognitive_os"

# ------------------------------------------
# AI Provider Router - 5 Provider Configuration
# Local-first: OLLAMA is default, others route by task type
# ------------------------------------------

# OLLAMA (Local Default - FREE)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama2"
OLLAMA_ENABLED="true"

# DEEPSEEK (Coding & Debugging)
DEEPSEEK_API_KEY="sk-fee2b85f8fd24369994a5307350af182"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_ENABLED="true"

# GEMINI (Long Context & Memory Analysis)
GEMINI_API_KEY="AIzaSyB-APtrgunj5h93y-mJ_Z2LYSUAxMCl3yI"
GEMINI_MODEL="gemini-pro"
GEMINI_ENABLED="true"

# GROK (External Research & Market Context)
GROK_API_KEY=""
GROK_MODEL="grok-1"
GROK_ENABLED="false"

# OPENAI (Strategic Planning & Architecture)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"
OPENAI_ENABLED="false"

# AI Service Configuration
AI_SERVICE_URL="http://localhost:8000"
AI_PROVIDER="auto"  # auto | ollama | deepseek | gemini | grok | openai

# Legacy (deprecated, use AI_PROVIDER)
# AI_PROVIDER_LEGACY="gemini"

# ------------------------------------------
# AUTONOMOUS AI AGENT CONFIGURATION
# ------------------------------------------

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_URL=""

# Autonomous Agent Settings
AUTONOMOUS_AGENT_ENABLED="false"
MAX_AUTONOMY_LEVEL="7"
AUTO_LEARNING_ENABLED="true"
AUTO_EXECUTION_ENABLED="false"

# Career Automation
AUTO_JOB_APPLY_ENABLED="false"
JOB_SEARCH_PREFERENCES=""
RESUME_TEMPLATE_PATH=""

# Communication Automation
AUTO_COMMUNICATION_ENABLED="false"
COMMUNICATION_CHANNELS="telegram,email"
RESPONSE_STYLE="professional"

# Scheduling Automation
AUTO_SCHEDULING_ENABLED="false"
CALENDAR_INTEGRATION="google"
SCHEDULING_PREFERENCES="optimize_for_productivity"

# Content Creation
AUTO_CONTENT_CREATION="false"
CONTENT_PLATFORMS="blog,linkedin,github"
CONTENT_STYLE="professional"

# Learning & Adaptation
LEARNING_RATE="0.1"
PATTERN_RECOGNITION_ENABLED="true"
CONTINUOUS_IMPROVEMENT="true"

# Safety & Permissions
REQUIRE_CONFIRMATION_FOR="job_applications,financial_decisions"
LOG_ALL_AUTONOMOUS_ACTIONS="true"
EMERGENCY_STOP_ENABLED="true"

# ------------------------------------------
# Application Configuration
# ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Time Display (24h format)
NEXT_PUBLIC_TIME_FORMAT="24h"
NEXT_PUBLIC_SHOW_SECONDS="true"

# ------------------------------------------
# Telegram Bot Integration (Optional)
# ------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_ENABLED="false"

# ------------------------------------------
# Feature Flags
# ------------------------------------------
ENABLE_VOICE_CAPTURE="false"
ENABLE_IMAGE_CAPTURE="false"
ENABLE_AI_ROUTING="true"
ENABLE_TIME_DISPLAY="true"

# ------------------------------------------
# Development Only
# ------------------------------------------
DEBUG_AI_ROUTING="true"
LOG_LEVEL="info"
