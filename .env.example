# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/cognitive_os"

# ============================================
# AI PROVIDER SELECTION
# ============================================
# Choose your AI provider: openai, deepseek, kimik2, ollama, custom
AI_PROVIDER="openai"

# OpenAI Configuration (Expensive but high quality)
# Get key from: https://platform.openai.com
OPENAI_API_KEY="your-openai-api-key-here"

# DeepSeek Configuration (CHEAPEST OPTION - 90% cheaper than OpenAI!)
# Get key from: https://platform.deepseek.com
# Models: deepseek-chat, deepseek-reasoner, deepseek-coder
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# Kimi K2 Configuration (Good for Chinese language tasks)
# Get key from: https://platform.moonshot.cn
# Models: kimi-k2, kimi-k1, kimi-moonshot
KIMIK2_API_KEY="your-kimi-api-key-here"

# Ollama Configuration (FREE - runs locally on your machine!)
# Install Ollama from: https://ollama.com
# Then run: ollama run llama3.2
OLLAMA_BASE_URL="http://localhost:11434"

# Custom OpenAI-Compatible API
# For any provider with OpenAI-compatible endpoints
CUSTOM_AI_BASE_URL="https://api.your-provider.com/v1"
CUSTOM_AI_API_KEY="your-custom-api-key"

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Development Settings
NODE_ENV="development"
